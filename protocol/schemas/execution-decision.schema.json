{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dsg.dev/schemas/execution-decision.json",
  "title": "DSG Execution Decision",
  "type": "object",
  "required": ["decision", "stability_score", "reason", "agent_id", "action", "evaluated_at"],
  "properties": {
    "decision": {
      "type": "string",
      "enum": ["ALLOW", "STABILIZE", "BLOCK"]
    },
    "stability_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "reason": { "type": "string" },
    "agent_id": { "type": "string" },
    "action": { "type": "string" },
    "evaluated_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": true
}
